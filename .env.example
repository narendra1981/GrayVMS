# Camera 1 alert threshold: alert triggers when max_people > threshold
CAMERA1_MAX_PEOPLE_ALERT_THRESHOLD=10

# SMS resend cooldown while alert remains active (seconds)
SMS_ALERT_COOLDOWN_SECONDS=300

# Twilio credentials for SMS alerts
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# One or more destination numbers, comma-separated
TWILIO_TO_NUMBERS=+1111111111,+2222222222

# Twilio WhatsApp sender and one or more recipients (comma-separated)
# Use either +123... or whatsapp:+123... format
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO_NUMBERS=+1111111111,+2222222222
